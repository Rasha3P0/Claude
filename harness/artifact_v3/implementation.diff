+function loadScriptOnce(src) {
+  return new Promise((resolve, reject) => {
+    if ([...document.scripts].some(s => s.src === src)) return resolve();
+    const el = document.createElement("script");
+    el.src = src; el.async = true; el.defer = true;
+    el.onload = () => resolve();
+    el.onerror = () => reject(new Error("Could not load " + src + " (offline or blocked)."));
+    document.head.appendChild(el);
+  });
+}
+
+const googleDrive = (() => {
+  const GIS = "https://accounts.google.com/gsi/client";
+  const SCOPE = "https://www.googleapis.com/auth/drive.file";
+  let tokenClient = null;
+  let clientIdUsed = "";
+  let token = null;     // { value, exp } — in MEMORY ONLY, never persisted
+  let pending = null;   // { resolve, reject } for the in-flight token request
+  let fileId = "";      // resolved Drive file id, cached in-memory across writes
+
+  async function ensureClient(clientId) {
+    if (!clientId) throw new Error("No Google client id configured.");
+    await loadScriptOnce(GIS);
+    if (!(window.google && google.accounts && google.accounts.oauth2))
+      throw new Error("Google Identity Services unavailable.");
+    if (!tokenClient || clientIdUsed !== clientId) {
+      tokenClient = google.accounts.oauth2.initTokenClient({
+        client_id: clientId, scope: SCOPE,
+        callback: (resp) => {
+          if (!pending) return;
+          if (resp && resp.access_token) {
+            token = { value: resp.access_token, exp: Date.now() + (resp.expires_in || 3600) * 1000 };
+            pending.resolve(token.value);
+          } else {
+            pending.reject(new Error((resp && resp.error) || "Authorisation failed."));
+          }
+          pending = null;
+        },
+        error_callback: (err) => {
+          if (pending) { pending.reject(new Error((err && err.message) || "Authorisation was cancelled.")); pending = null; }
+        }
+      });
+      clientIdUsed = clientId;
+    }
+  }
