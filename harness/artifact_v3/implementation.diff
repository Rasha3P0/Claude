+  async function getToken(clientId, interactive) {
+    await ensureClient(clientId);
+    if (token && token.exp - 60000 > Date.now()) return token.value;
+    return new Promise((resolve, reject) => {
+      // Sequential use only (one alert write at a time); a new request supersedes any stale one.
+      if (pending) pending.reject(new Error("Superseded by a newer auth request."));
+      pending = { resolve, reject };
+      // prompt:"" attempts silent re-auth if already granted; "consent" forces the dialog.
+      try { tokenClient.requestAccessToken({ prompt: interactive ? "consent" : "" }); }
+      catch (e) { pending = null; reject(e); }
