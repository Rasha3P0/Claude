+    if (((cur.drive || {}).fileId) !== id) saveSettings({ ...cur, drive: { ...(cur.drive || {}), fileId: id } });
+  }
+
+  async function resolveFile(settings, saveSettings) {
+    const d = settings.drive || {};
+    const cid = d.clientId;
+    const known = fileId || d.fileId;   // prefer the in-memory id, fall back to settings
+    if (known) {                        // cached id still alive?
+      const r = await api(`https://www.googleapis.com/drive/v3/files/${known}?fields=id,trashed`, {}, cid);
+      if (r.ok) { const j = await r.json(); if (!j.trashed) { rememberId(settings, saveSettings, known); return known; } }
+    }
+    // find by the app's marker so re-installs re-link the same file (files.list under
+    // drive.file returns only app-created files — exactly our own log)
+    const q = encodeURIComponent("appProperties has { key='groundControl' and value='portfolioLog' } and trashed=false");
+    const find = await api(`https://www.googleapis.com/drive/v3/files?q=${q}&spaces=drive&fields=files(id,name)`, {}, cid);
