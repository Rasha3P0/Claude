# ─── Waitlist: Google Sheet (service account) ─────────────────────────────────
# Create a service account in GCP, download the JSON key, share the Sheet with
# the service account email (Editor), then fill in the two values below.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_ID=1abc_the_sheet_id_from_the_url_xyz

# ─── Waitlist: Gmail confirmation email (OAuth2 — personal Gmail) ──────────────
# 1. Create OAuth2 credentials in GCP (Web Application type)
# 2. Go to https://developers.google.com/oauthplayground
# 3. Authorise scope: https://www.googleapis.com/auth/gmail.send
# 4. Exchange auth code for tokens — copy the refresh token below
GMAIL_CLIENT_ID=xxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...
GMAIL_FROM_EMAIL=you@gmail.com

# ─── Deployment ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-vercel-subdomain.vercel.app
